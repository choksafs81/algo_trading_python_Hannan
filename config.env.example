# Environment configuration for Algorithmic Trading System

# Application settings
APP_NAME="Algorithmic Trading System"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database settings
DATABASE_URL=sqlite:///./trading.db

# Redis settings
REDIS_URL=redis://localhost:6379

# IBKR TWS settings
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Market data API keys (get these from respective providers)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
POLYGON_API_KEY=your_polygon_api_key_here

# Trading settings
MAX_POSITION_SIZE=10000.0
RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log
